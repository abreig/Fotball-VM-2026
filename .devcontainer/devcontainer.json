{
  "name": "Fotball-VM 2026 prediksjoner",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "make data || echo 'Datahenting feilet, bruker seed-data'",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Prediksjonsnettside",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
